{
  "name": "resurgo",
  "version": "2.0.0",
  "description": "Resurgo — AI-Powered Life Transformation System",
  "private": true,
  "scripts": {
    "dev": "npx convex dev --until-success && next dev",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$conn = Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1; if ($conn) { Stop-Process -Id $conn.OwningProcess -Force -ErrorAction SilentlyContinue }; Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; npm run dev\"",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:convex": "npx convex deploy --cmd \"next build\"",
    "start": "next start",
    "verify:deploy": "npm run typecheck && npm run build",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ics": "jest src/lib/__tests__/ics.compatibility.test.ts",
    "test:chatbot-regression": "jest src/lib/__tests__/chatbot.regression.test.ts src/app/api/chatbot/route.test.ts src/app/api/chatbot/events/route.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "node scripts/build-android.js",
    "android:build:release": "node scripts/build-android.js release"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@clerk/nextjs": "^6.37.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dodopayments/convex": "^0.2.8",
    "@next/bundle-analyzer": "^16.1.6",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/analytics": "^1.6.1",
    "canvas-confetti": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "convex": "^1.31.7",
    "convex-helpers": "^0.1.112",
