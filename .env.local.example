# ═══════════════════════════════════════════════════════════════════════════════
# RESURGO - Environment Variables
# Copy this file to .env.local and fill in your values
# Domain: resurgo.life
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Clerk Authentication ─────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
CLERK_JWT_ISSUER_DOMAIN=https://your-domain.clerk.accounts.dev
# Optional backwards-compatible alias if you already configured this name
CLERK_FRONTEND_API_URL=https://your-domain.clerk.accounts.dev

# ─── Convex ───────────────────────────────────────────────────────────────────
CONVEX_DEPLOYMENT=dev:your-project-name
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ─── AI API KEYS (server-side only) ──────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_AI_STUDIO_KEY=
GOOGLE_AI_STUDIO_KEY_BACKUP=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
AIML_API_KEY=
BRAVE_SEARCH_API_KEY=
# ─── Ollama (local AI — zero cloud cost) ────────────────────────────
# Set to your Ollama server URL when running locally (default: http://localhost:11434)
# Leave empty or omit entirely in production/Vercel to skip Ollama automatically.
# Available models: dolphin-phi:latest (fast/free), dolphin3:latest (premium),
#                   aeline/phil:latest, aeline/halo:latest, llama2-uncensored:7b
OLLAMA_BASE_URL=http://localhost:11434
# ─── Billing (Clerk-hosted pricing/checkout) ────────────────────────────────
BILLING_WEBHOOK_SYNC_SECRET=
BILLING_PRO_MONTHLY_CHECKOUT_URL=
BILLING_PRO_YEARLY_CHECKOUT_URL=
BILLING_LIFETIME_CHECKOUT_URL=
BILLING_PORTAL_URL=

# ─────────────────────────────────────────────────────────────────────────────────
# DODO PAYMENTS (Billing — set in BOTH .env.local AND Convex dashboard)
# Dashboard: https://app.dodopayments.com/
# ─────────────────────────────────────────────────────────────────────────────────

# Server-side API key (set in Convex env vars too)
# Convex env key name: DODO_PAYMENTS_API_KEY
DODO_PAYMENTS_API_KEY=dodo_test_...

# Environment: test_mode | live_mode (set in Convex env vars too)
# Convex env key name: DODO_PAYMENTS_ENVIRONMENT
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Webhook secret from Dodo dashboard → Developer → Webhooks
# Convex env key name: DODO_PAYMENTS_WEBHOOK_SECRET
DODO_PAYMENTS_WEBHOOK_SECRET=whsec_...

# Product IDs (copy from Dodo dashboard after creating products)
# ⚠️  Also update the fallback values in src/components/BillingCTA.tsx
# Convex env key names: DODO_PRODUCT_ID_PRO_MONTHLY, DODO_PRODUCT_ID_PRO_YEARLY, DODO_PRODUCT_ID_LIFETIME
NEXT_PUBLIC_DODO_PRODUCT_PRO_MONTHLY=pdt_...
NEXT_PUBLIC_DODO_PRODUCT_PRO_YEARLY=pdt_...
NEXT_PUBLIC_DODO_PRODUCT_LIFETIME=pdt_...

# Internal sync secret — generate any random string, set in Convex env vars too
# Convex env key name: BILLING_WEBHOOK_SYNC_SECRET
BILLING_WEBHOOK_SYNC_SECRET=

# ─────────────────────────────────────────────────────────────────────────────────
# DISCORD NOTIFICATIONS (Billing alerts — set in Convex env vars)
# Create webhooks: Server Settings → Integrations → Webhooks
# ─────────────────────────────────────────────────────────────────────────────────

# Webhook URL for #payments / #alerts channel (payment events, signups)
# Convex env key name: DISCORD_ALERTS_WEBHOOK_URL
DISCORD_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Webhook URL for #community channel (goal achievements, milestones)
# Used by src/app/api/discord/route.ts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Public invite link for your Discord server
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-server

# ─────────────────────────────────────────────────────────────────────────────────
# RESEND (Transactional emails — set in BOTH .env.local AND Convex env vars)
# Dashboard: https://resend.com/
# ─────────────────────────────────────────────────────────────────────────────────

# Server-side API key
# Convex env key name: RESEND_API_KEY
RESEND_API_KEY=re_...

# From address (must be a verified domain in Resend)
# Convex env key name: RESEND_FROM_EMAIL
RESEND_FROM_EMAIL=Resurgo <noreply@resurgo.life>

# ─────────────────────────────────────────────────────────────────────────────────
# ANALYTICS
# ─────────────────────────────────────────────────────────────────────────────────

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS (Optional)
# ─────────────────────────────────────────────────────────────────────────────────

# VAPID Keys for Web Push
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@resurgo.life

# ─────────────────────────────────────────────────────────────────────────────────
# SEO VERIFICATION (Add your verification codes)
# ─────────────────────────────────────────────────────────────────────────────────

# Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code

# Bing Webmaster
NEXT_PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_code
