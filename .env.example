# ═══════════════════════════════════════════════════════════════════════════════
# RESURGO — Environment Variables (Vercel Production)
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

## TIER 1: CRITICAL (Required for deployment)
## ════════════════════════════════════════════════════════════════════════════════

# Clerk Authentication (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_
CLERK_WEBHOOK_SECRET=whsec_
# Clerk → Convex auth issuer domain.
# Official Convex docs call this CLERK_JWT_ISSUER_DOMAIN.
# You can also keep CLERK_FRONTEND_API_URL for backwards compatibility.
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev
CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Convex Backend (Real-time Database)
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=prod:your-deployment

# Application URLs
NEXT_PUBLIC_SITE_URL=https://resurgo.life
NEXT_PUBLIC_APP_URL=https://resurgo.life

## TIER 2: NEW/PRODUCTION (Email, Monitoring)
## ════════════════════════════════════════════════════════════════════════════════

# Resend Email (FREE: 100 emails/day)
# Signup: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Resurgo <noreply@resurgo.life>
EMAIL_INTERNAL_SECRET=resurgo-internal-email-secret-change-this

## TIER 3: AI PROVIDERS (Fallback chain via provider-router)
## ════════════════════════════════════════════════════════════════════════════════

# Groq (primary — free tier: 14,400 req/day)
GROQ_API_KEY=

# Google Gemini (secondary — free tier)
GOOGLE_AI_STUDIO_KEY=

# OpenRouter (fallback)
OPENROUTER_API_KEY=

# Additional AI providers (all optional)
AIML_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
BRAVE_SEARCH_API_KEY=
# Tavily Web Search for AI Coach internet access (free: 1,000 searches/month)
# Sign up at: https://app.tavily.com → API Keys
TAVILY_API_KEY=

## TIER 4: BILLING & WEBHOOKS
## ════════════════════════════════════════════════════════════════════════════════

BILLING_WEBHOOK_SYNC_SECRET=
BILLING_PRO_MONTHLY_CHECKOUT_URL=
BILLING_PRO_YEARLY_CHECKOUT_URL=
BILLING_LIFETIME_CHECKOUT_URL=
BILLING_PORTAL_URL=

## TIER 5: OPTIONAL (Telegram, Push Notifications, HuggingFace)
## ════════════════════════════════════════════════════════════════════════════════

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ResurgoBot

HF_ACCESS_TOKEN=

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@resurgo.life

## TIER 5: PUBLIC CONFIG (Safe to commit)
## ════════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_GA_ID=G-F1VLMSS8FB
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_APP_NAME=Resurgo
NEXT_PUBLIC_AI_PROVIDER=groq
NEXT_PUBLIC_AI_ENABLED=true
NEXT_PUBLIC_PUTER_ENABLED=true
NEXT_PUBLIC_AI_MAX_TOKENS_FREE=512
NEXT_PUBLIC_AI_MAX_TOKENS_PREMIUM=2048
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://resurgo.life

## TIER 6: MARKETING & SOCIAL INTEGRATIONS
## ════════════════════════════════════════════════════════════════════════════════

# ── X / Twitter (OAuth 1.0a + OAuth 2.0 + Bearer) ────────────────────────────
# 1. developer.twitter.com → Projects & Apps → Create Project → Create App
# 2. App Settings → Keys and Tokens → Generate all tokens
# Bearer Token: App-only auth for read endpoints (search, metrics)
TWITTER_BEARER_TOKEN=
# Consumer Keys (OAuth 1.0a — needed for posting tweets)
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
# Access Token & Secret (OAuth 1.0a user context — YOUR account posting)
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
# OAuth 2.0 Client (for PKCE flows if needed)
TWITTER_OAUTH2_CLIENT_ID=
TWITTER_OAUTH2_CLIENT_SECRET=

# ── LinkedIn (OAuth 2.0) ─────────────────────────────────────────────────────
# 1. linkedin.com/developers → Create App → Request access to Marketing APIs
# 2. Auth tab → Generate Access Token (expires in 60 days, refresh it)
# 3. Person URN: linkedin.com/developers → Your App → Auth → Use /v2/me to get URN
# Recommendation: Post from your PERSONAL LinkedIn. Create a company page later.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID
LINKEDIN_ORG_URN=

# ── Instagram Graph API ──────────────────────────────────────────────────────
# 1. Connect Instagram Business/Creator account to a Facebook Page
# 2. business.facebook.com → Instagram Accounts → Link
# 3. Generate token with instagram_basic, instagram_content_publish permissions
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── Facebook / Meta (Pixel + Conversions API) ────────────────────────────────
# 1. Create pixel: business.facebook.com → Events Manager → Add Data Source
# 2. System user token: Business Settings → Users → System Users → Generate Token
# 3. Permissions needed: ads_management, business_management, pages_read_engagement
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_PIXEL_ID=your-pixel-id
META_ACCESS_TOKEN=your-system-user-token
META_BUSINESS_ID=your-business-id
META_TEST_EVENT_CODE=TEST12345

# ── Discord (Webhook for community notifications) ─────────────────────────────
# 1. Open Discord server → channel Settings → Integrations → Webhooks → New Webhook
# 2. Copy webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_ALERTS_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-server

# ── Reddit API ────────────────────────────────────────────────────────────────
# 1. reddit.com/prefs/apps → Create App → type: script
# 2. Name: resurgo-bot, redirect_uri: http://localhost:8080
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
REDDIT_USER_AGENT=Resurgo/1.0

# ── Email Marketing Config ────────────────────────────────────────────────────
# Resend domain: Add resurgo.life in resend.com/domains, verify DNS
# After verification you can send FROM any @resurgo.life address
RESEND_FROM_MARKETING=Resurgo <marketing@resurgo.life>
RESEND_FROM_SUPPORT=Resurgo <support@resurgo.life>

## TIER 7: FOOD & NUTRITION APIs (All free tier)
## ════════════════════════════════════════════════════════════════════════════════

# USDA FoodData Central (free, no billing required)
# Register at: https://api.nal.usda.gov/
USDA_FOODDATA_API_KEY=DEMO_KEY

# Spoonacular (free tier: 150 requests/day)
# Register at: https://spoonacular.com/food-api/console#Dashboard
SPOONACULAR_API_KEY=

## TIER 8: ADMIN & SECURITY
## ════════════════════════════════════════════════════════════════════════════════

# Admin access control
# ADMIN_SECRET: used to authorize admin API calls from server-side tools
# ADMIN_EMAILS: comma-separated list of admin email addresses
ADMIN_SECRET=choose-a-strong-random-secret-here
ADMIN_EMAILS=support@resurgo.life

